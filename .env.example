# STRATOSPHERE - Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Database
DB_HOST=localhost
DB_NAME=STRATOSPHERE
DB_USER=stratos_user
DB_PASS=your_secure_password_here

# Session lifetime in seconds (default: 3600 = 1h)
SESSION_LIFETIME=3600

# Login rate limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

# Set to 'development' to enable error display
APP_ENV=production
