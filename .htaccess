# STRATOSPHERE - Root .htaccess
# Security headers and access control

Options -Indexes -MultiViews

# Deny access to sensitive files
<FilesMatch "\.(env|sql|log|md|git|sh|bak|swp)$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.rawgit.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://unpkg.com https://use.fontawesome.com; img-src 'self' data: https://*.tile.openstreetmap.org https://cdn.rawgit.com https://cdnjs.cloudflare.com blob:; font-src 'self' https://use.fontawesome.com; connect-src 'self';"
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    # Redirect to HTTPS in production (uncomment when SSL is configured)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>
